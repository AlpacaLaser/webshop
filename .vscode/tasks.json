{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "dotnet run --project /workspace/backend/Webshop.API",
      "group": "build",
      "presentation": { "panel": "new", "reveal": "always" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "cd /workspace/frontend && npx ng serve --host 0.0.0.0 --proxy-config proxy.conf.json",
      "group": "build",
      "presentation": { "panel": "new", "reveal": "always" },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "Start All",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
